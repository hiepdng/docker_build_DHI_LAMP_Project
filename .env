## Host system UID and GID of a persson who run the containers
UID=1000
GID=1000

## Name of your container
PROJECT_NAME=lamp

### For HTTPD ----------------------------------------
HTTPDVERSION=httpd:2.4.68-debian13
DOCUMENT_ROOT=./htdocs
HTTPD_CERT_DIR=./certs/httpd
HOST_UNSECURE_PORT=80
HOST_SECURE_PORT=443
SERVER_NAME="httpd_server"
SERVER_ADMIN="you@example.com"
HTTPD_CERT_SUBJ="/C=US/ST=state/L=City/O=Organization/OU=Department/CN=httpd_server/emailAddress=you@example.com"


### For PHP-FPM ----------------------------------------
PHPVERSION=php:8.5.8-debian13-fpm
HOST_PHP_PORT=9000


### For MySQL -------------------------------------------
MYSQLVERSION=mysql:lts-debian13
MYSQL_DATA_DIR=./mysql_data
MYSQL_CERT_DIR=./certs/mysql
HOST_MYSQL_PORT=3306
HOST_MYSQLX_PORT=33060
#MYSQL_ROOT_PASSWORD_FILE=
MYSQL_ROOT_PASSWORD=my-secret-pw
MYSQL_CA_CERT_SUBJ="/C=US/ST=state/L=City/O=Organization/OU=Department/CN=MySQL_CA/emailAddress=you@example.com"
MYSQL_SERVER_CERT_SUBJ="/C=US/ST=state/L=City/O=Organization/OU=Department/CN=mysql_server/emailAddress=you@example.com"
MYSQL_CLIENT_CERT_SUBJ="/C=US/ST=state/L=City/O=Organization/OU=Department/CN=php-fpm_server/emailAddress=you@example.com"




