## Name of your container
PROJECT_NAME=lamp

### For HTTPD ----------------------------------------
HTTPDVERSION=httpd:2.4.68-debian13
DOCUMENT_ROOT=./htdocs
#SSL_CERT_DIR=./ssl_cert_dir
SSL_CERT_FILE
HOST_UNSECURE_PORT=80
HOST_SECURE_PORT=443
SERVER_NAME="www.example.com"
SERVER_ADMIN="you@example.com"
CERT_SUBJ="/C=US/ST=state/L=City/O=Organization/OU=Department/CN=server.example.com/emailAddress=you@example.com"


### For PHP-FPM ----------------------------------------
PHPVERSION=php:8.5.8-debian13-fpm
HOST_PHP_PORT=9000


### For MySQL -------------------------------------------
MYSQLVERSION=mysql:lts-debian13
MYSQL_DATA_DIR=./mysql_data
HOST_MYSQL_PORT=3306
HOST_MYSQLX_PORT=33060
#MYSQL_ROOT_PASSWORD_FILE=
MYSQL_ROOT_PASSWORD=my-secret-pw
MYSQL_OPTIONS="--max-connections=50 --connect_timeout=30"

# my.cnf file as a variable
MYCNF="[mysqld]
ssl-ca=/etc/ca.pem
ssl-cert=/etc/server-cert.pem
ssl-key=/etc/server-key.pem
bind-address = *
require_secure_transport = ON

max_connections         = 150
max_connect_errors      = 100
connect_timeout         = 10
wait_timeout            = 28800
interactive_timeout     = 28800
back_log                = 10000

innodb_buffer_pool_size = 134217728
innodb_file_per_table   = ON
innodb_flush_log_at_trx_commit = 1
innodb_flush_method     = O_DIRECT

log_error               = stderr
slow_query_log          = OFF
long_query_time         = 10.000000"




